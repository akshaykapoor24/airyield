# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=AirYield
DEBUG=false

# ─── Database ─────────────────────────────────────────────────────────────────
# Async URL (used by FastAPI / SQLAlchemy async engine)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/airyield
# Sync URL (used by Alembic migrations)
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/airyield

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000"]

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Platform Admin (only used by create_platform_admin.py) ───────────────────
ADMIN_EMAIL=admin@airyield.com
ADMIN_FULL_NAME=Platform Admin
ADMIN_PASSWORD=
